{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_INSTALL_BINDIR": ".",
        "CMAKE_INSTALL_LIBDIR": ".",
        "BUILD_APP": "ON"
      }
    },
    {
      "name": "macos-clang",
      "displayName": "macOS clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "windows-arm64",
      "displayName": "Windows arm64 clang-cl",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl.exe",
        "CMAKE_CXX_COMPILER": "clang-cl.exe",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "SWIFT_ROOT": "$penv{USERPROFILE}/AppData/Local/Programs/Swift",
        "SWIFT_VERSION": "6.3.1",
        "PP_BUILD_VENDOR_PREBUILT_URL": "https://github.com/partout-io/prebuilts/releases/download/0.4.0"
      },
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-debug",
      "configurePreset": "macos-clang",
      "configuration": "Debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-clang",
      "configuration": "Release"
    },
    {
      "name": "windows-arm64-debug",
      "configurePreset": "windows-arm64",
      "configuration": "Debug"
    },
    {
      "name": "windows-arm64-release",
      "configurePreset": "windows-arm64",
      "configuration": "Release"
    }
  ]
}
