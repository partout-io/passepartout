{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppProfileHeader",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "moduleTypes": {
      "type": "array",
      "items": {
        "$ref": "../partout/ModuleType.schema.json"
      }
    },
    "primaryModuleType": {
      "$ref": "../partout/ModuleType.schema.json"
    },
    "secondaryModuleTypes": {
      "type": "array",
      "items": {
        "$ref": "../partout/ModuleType.schema.json"
      }
    },
    "providerInfo": {
      "$ref": "ProviderInfo.schema.json"
    },
    "fingerprint": {
      "type": "string"
    },
    "sharingFlags": {
      "type": "array",
      "items": {
        "$ref": "ProfileSharingFlag.schema.json"
      }
    },
    "requiredFeatures": {
      "type": "array",
      "items": {
        "$ref": "AppFeature.schema.json"
      }
    }
  },
  "required": [
    "id",
    "name",
    "moduleTypes",
    "secondaryModuleTypes",
    "fingerprint",
    "sharingFlags",
    "requiredFeatures"
  ]
}
